# Infra image versions (актуально на 2026-03-17):
POSTGRES_IMAGE=postgres:18.3
KAFKA_IMAGE=apache/kafka:4.2.0

# Postgres
POSTGRES_DB=mdm
POSTGRES_USER=mdm
POSTGRES_PASSWORD=mdm
POSTGRES_PORT=5432

# Kafka
KAFKA_PORT=9092
KAFKA_ADVERTISED_HOST=localhost

# Kafka UI
KAFKA_UI_IMAGE=provectuslabs/kafka-ui:v0.7.2
KAFKA_UI_PORT=8088
KAFKA_CLUSTER_NAME=mdm-local
